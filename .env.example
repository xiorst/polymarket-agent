# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# REST API — protect all /api/v1/* endpoints
AGENT_SERVER_API_KEY=generate-a-strong-random-key-here

# Database
AGENT_DATABASE_PASSWORD=your_secure_db_password

# Blockchain (LIVE MODE ONLY — leave empty for paper mode)
AGENT_BLOCKCHAIN_PRIVATE_KEY=0x_your_hot_wallet_private_key
AGENT_BLOCKCHAIN_RPC_URL=https://polygon-rpc.com
AGENT_BLOCKCHAIN_CTF_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E

# Polymarket CLOB API key (for order placement in live mode)
AGENT_BLOCKCHAIN_POLYMARKET_API_KEY=your_polymarket_api_key

# Auto-Withdraw cold wallet (LIVE MODE ONLY)
AGENT_AUTO_WITHDRAW_SAFE_WALLET_ADDRESS=0x_your_cold_wallet_address

# Telegram Notifications
AGENT_NOTIFICATION_TELEGRAM_BOT_TOKEN=your_bot_token
AGENT_NOTIFICATION_TELEGRAM_CHAT_ID=your_chat_id

# Trading Mode: paper (default, safe) | live (real money)
AGENT_TRADING_MODE=paper

# Telegram Feed — second account userbot for external news context
AGENT_TELEGRAM_FEED_API_ID=your_api_id_here
AGENT_TELEGRAM_FEED_API_HASH=your_api_hash_here
AGENT_TELEGRAM_FEED_PHONE=+628xxxxxxxxxx
AGENT_TELEGRAM_FEED_ENABLED=false   # set true after credentials configured

# Telegram Feed (External News Context for ML)
# Use second account — NOT main account
AGENT_TELEGRAM_FEED_API_HASH=your_api_hash_from_my_telegram_org
AGENT_TELEGRAM_FEED_PHONE=+628xxxxxxxxxx
# api_id set in config.yaml: telegram_feed.api_id (integer, not sensitive)
